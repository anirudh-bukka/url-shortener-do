# Copy to `.env` for local development (docker-compose reads this file).
# NEVER commit the real `.env` — it is git-ignored.

# ----- Application -----
# Public base URL used to build the returned short links (no trailing slash).
APP_BASE_URL=http://localhost:8080
# Active Spring profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# ----- PostgreSQL -----
POSTGRES_DB=urlshortener
POSTGRES_USER=urlshortener
POSTGRES_PASSWORD=change-me-in-real-environments
# JDBC URL the app uses to reach Postgres. In docker-compose the host is the service name `db`.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/urlshortener
SPRING_DATASOURCE_USERNAME=urlshortener
SPRING_DATASOURCE_PASSWORD=change-me-in-real-environments

# ----- Redis (optional cache). Leave host blank to disable caching. -----
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
